# ---------------------------------------------------------------------------
# Torneo del Poder — environment configuration
# Copy this file to `.env` and fill in the values you need.
# The app runs fully without any keys: YouTube/Spotify single-track import
# works via public oEmbed endpoints. Keys unlock richer imports.
# ---------------------------------------------------------------------------

# Server
PORT=3000
NODE_ENV=development

# Public URL used to build shareable room links (no trailing slash).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- YouTube ---------------------------------------------------------------
# Optional. Required ONLY for importing full YouTube *playlists* (uses the
# YouTube Data API v3). Single-video import works without it via oEmbed.
YOUTUBE_API_KEY=

# --- Spotify ---------------------------------------------------------------
# Optional. Single-track import works via oEmbed without credentials.
# Provide these to enable full Spotify *playlist* import (Client Credentials).
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# --- Database (future persistence, see prisma/schema.prisma) ---------------
# The live tournament runtime is in-memory; the database is used for optional
# persistence and future features (history, accounts, public tournaments).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/torneo?schema=public"
